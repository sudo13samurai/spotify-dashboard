<!DOCTYPE html>

<html>
<head>
  <title>Spotify Dashboard</title>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <script src="/js/music-dna.js"></script>

  <style>
    body {
      font-family: Arial;
      background: #0e0e0e;
      color: white;
      text-align: center;
    }

    canvas {
      max-width: 600px;
      margin: auto;
    }
  </style>

</head>

<body>

<h1>Your Spotify Music DNA</h1>

<canvas id="musicDNA"></canvas>

<script>

const profile = {
  energy: <%= profile.energy %>,
  danceability: <%= profile.danceability %>,
  acousticness: <%= profile.acousticness %>,
  instrumentalness: <%= profile.instrumentalness %>,
  valence: <%= profile.valence %>,
  tempo: <%= profile.tempo %>
};

renderMusicDNA(profile);

</script>

</body>
</html>
